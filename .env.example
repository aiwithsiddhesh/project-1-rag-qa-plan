# OpenAI API key used by generation and optional HyDE expansion.
OPENAI_API_KEY=

# Chat model used by the generator.
OPENAI_MODEL=gpt-3.5-turbo

# Local FAISS vector store directory.
VECTOR_STORE_PATH=./data/vectorstore

# SentenceTransformer embedding model for dense retrieval.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CrossEncoder model for reranking retrieved chunks.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Document chunking controls.
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval controls.
TOP_K_RESULTS=5
FETCH_K_MULTIPLIER=4
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6

# Query expansion toggle.
USE_HYDE=false

# Optional LangSmith tracing. Enabled only when LANGSMITH_API_KEY is set.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=project-1-rag-qa

# Logging and API settings.
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
